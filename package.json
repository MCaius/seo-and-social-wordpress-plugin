{
  "name": "seo-and-social-wordpress-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:zip": "node scripts/build-zip.mjs",
    "syntax:php": "find seo-and-social -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test:settings": "php -d zend.assertions=1 -d assert.exception=1 tests/settings-save-regression.php",
    "test:rest-permission": "php -d zend.assertions=1 -d assert.exception=1 tests/settings-endpoint-permission.php",
    "test:access": "php -d zend.assertions=1 -d assert.exception=1 tests/plugin-access-capability.php",
    "test:llms": "php -d zend.assertions=1 -d assert.exception=1 tests/llms-public-output.php",
    "lint:php": "composer lint:php",
    "validate": "npm run syntax:php && npm run test:settings && npm run test:rest-permission && npm run test:access && npm run test:llms && npm run build:zip"
  }
}
